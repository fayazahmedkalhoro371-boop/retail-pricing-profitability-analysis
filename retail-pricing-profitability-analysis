3. Product Classification (CASE + Window Functions)

```sql
-- ============================================
-- Strategic product classification
-- Identifies critical issues and opportunities
-- ============================================

WITH product_metrics AS (
    SELECT 
        p.product_name,
        p.category,
        r.region_name,
        SUM(t.quantity_sold - t.units_returned) AS total_net_units,
        ROUND(SUM(t.actual_selling_price * (t.quantity_sold - t.units_returned)), 2) AS total_revenue,
        ROUND(SUM(p.unit_cost * (t.quantity_sold - t.units_returned)), 2) AS total_cogs,
        ROUND(AVG(t.discount_pct), 2) AS avg_discount_pct,
        ROUND(SUM(
            (t.actual_selling_price * (t.quantity_sold - t.units_returned)) - 
            (p.unit_cost * (t.quantity_sold - t.units_returned))
        ), 2) AS total_gross_profit
    FROM sales_transactions t
    JOIN products p ON t.product_id = p.product_id
    JOIN regions r ON t.region_id = r.region_id
    GROUP BY p.product_name, p.category, r.region_name
),

ranked_products AS (
    SELECT 
        *,
        RANK() OVER (PARTITION BY region_name ORDER BY total_gross_profit DESC) AS profit_rank,
        ROW_NUMBER() OVER (PARTITION BY category ORDER BY total_gross_profit DESC) AS category_rank,
        ROUND((total_gross_profit / NULLIF(total_revenue, 0)) * 100, 2) AS gross_margin_pct,
        
        CASE 
            WHEN total_gross_profit < 0 AND avg_discount_pct > 25 THEN 'CRITICAL: Loss-Making + High Discount'
            WHEN gross_margin_pct < 10 AND avg_discount_pct > 25 THEN 'WARNING: Margin Erosion'
            WHEN gross_margin_pct > 20 AND avg_discount_pct <= 20 THEN 'HEALTHY: Profitable with Discount'
            WHEN gross_margin_pct > 30 AND avg_discount_pct < 10 THEN 'EXCELLENT: High Margin, Low Discount'
            ELSE 'NEUTRAL: Review Required'
        END AS classification
        
    FROM product_metrics
)

SELECT 
    product_name,
    category,
    region_name,
    total_revenue,
    total_gross_profit,
    gross_margin_pct,
    avg_discount_pct,
    profit_rank,
    classification
FROM ranked_products
WHERE classification IN ('CRITICAL: Loss-Making + High Discount', 'WARNING: Margin Erosion')
ORDER BY classification, total_gross_profit ASC;
```

