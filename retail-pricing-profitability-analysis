2. Profit Calculation (Correct Retail Accounting)

```sql
-- ============================================
-- Profit metrics - Retail accounting standard
-- Revenue and COGS both adjusted for returns
-- ============================================

WITH base_transactions AS (
    SELECT 
        t.transaction_id,
        t.product_id,
        t.region_id,
        t.customer_id,
        t.order_id,
        t.sale_date,
        t.quantity_sold,
        t.units_returned,
        t.actual_selling_price,
        p.unit_cost,
        p.base_price,
        p.product_name,
        p.category,
        r.region_name,
        
        -- Net units (sold minus returned)
        (t.quantity_sold - t.units_returned) AS net_units,
        
        -- Revenue: Only from units NOT returned
        t.actual_selling_price * (t.quantity_sold - t.units_returned) AS net_revenue,
        
        -- COGS: Only for units NOT returned
        p.unit_cost * (t.quantity_sold - t.units_returned) AS cogs
        
    FROM sales_transactions t
    JOIN products p ON t.product_id = p.product_id
    JOIN regions r ON t.region_id = r.region_id
),

profit_calculations AS (
    SELECT 
        *,
        -- Gross Profit: Revenue - COGS (returns already removed)
        net_revenue - cogs AS gross_profit,
        
        -- Gross Margin %
        ROUND(((net_revenue - cogs) / NULLIF(net_revenue, 0)) * 100, 2) AS gross_margin_pct,
        
        -- Profit per unit
        (net_revenue - cogs) / NULLIF(net_units, 0) AS profit_per_unit,
        
        -- Estimated revenue foregone due to discounts (corrected: comparing same quantity)
        (base_price * net_units) - net_revenue AS estimated_discount_revenue_foregone
        
    FROM base_transactions
)

SELECT * FROM profit_calculations;
```

