6. Executive KPIs (Finance Dashboard Metrics)

```sql
-- ============================================
-- EXECUTIVE KPIs: Finance dashboard metrics
-- ============================================

SELECT 
    COUNT(DISTINCT transaction_id) AS total_transactions,
    COUNT(DISTINCT customer_id) AS unique_customers,
    COUNT(DISTINCT product_id) AS products_analyzed,
    SUM(quantity_sold) AS total_units_sold,
    SUM(units_returned) AS total_units_returned,
    ROUND((SUM(units_returned) / NULLIF(SUM(quantity_sold), 0)) * 100, 2) AS return_rate_pct,
    ROUND(SUM(actual_selling_price * (quantity_sold - units_returned)), 2) AS total_revenue,
    ROUND(SUM(unit_cost * (quantity_sold - units_returned)), 2) AS total_cogs,
    ROUND(SUM(
        (actual_selling_price * (quantity_sold - units_returned)) - 
        (unit_cost * (quantity_sold - units_returned))
    ), 2) AS total_gross_profit,
    ROUND((SUM(
        (actual_selling_price * (quantity_sold - units_returned)) - 
        (unit_cost * (quantity_sold - units_returned))
    ) / NULLIF(SUM(actual_selling_price * (quantity_sold - units_returned)), 0)) * 100, 2) AS gross_margin_pct,
    ROUND(AVG(discount_pct), 2) AS avg_discount_pct,
    ROUND(AVG(actual_selling_price), 2) AS avg_selling_price,
    ROUND(SUM(actual_selling_price * (quantity_sold - units_returned)) / NULLIF(COUNT(DISTINCT transaction_id), 0), 2) AS revenue_per_transaction
FROM sales_transactions t
JOIN products p ON t.product_id = p.product_id;
```

