4. Data Validation (Critical Quality Checks)

```sql
-- ============================================
-- VALIDATION: Data quality checks
-- Demonstrates analytical discipline
-- ============================================

-- Check 1: Revenue is never negative
SELECT 
    'Revenue Non-Negative' AS check_name,
    COUNT(*) AS error_count,
    CASE 
        WHEN COUNT(*) = 0 THEN '✅ PASSED'
        ELSE '❌ FAILED'
    END AS status
FROM sales_transactions
WHERE actual_selling_price * (quantity_sold - units_returned) < 0;

-- Check 2: COGS is never negative
SELECT 
    'COGS Non-Negative' AS check_name,
    COUNT(*) AS error_count,
    CASE 
        WHEN COUNT(*) = 0 THEN '✅ PASSED'
        ELSE '❌ FAILED'
    END AS status
FROM sales_transactions t
JOIN products p ON t.product_id = p.product_id
WHERE p.unit_cost * (t.quantity_sold - t.units_returned) < 0;

-- Check 3: Units returned never exceed units sold
SELECT 
    'Returns ≤ Sales' AS check_name,
    COUNT(*) AS error_count,
    CASE 
        WHEN COUNT(*) = 0 THEN '✅ PASSED'
        ELSE '❌ FAILED'
    END AS status
FROM sales_transactions
WHERE units_returned > quantity_sold;

-- Check 4: Selling price never exceeds base price
SELECT 
    'Price ≤ Base Price' AS check_name,
    COUNT(*) AS error_count,
    CASE 
        WHEN COUNT(*) = 0 THEN '✅ PASSED'
        ELSE '❌ FAILED'
    END AS status
FROM sales_transactions t
JOIN products p ON t.product_id = p.product_id
WHERE t.actual_selling_price > p.base_price;

-- Check 5: Unit cost less than base price (positive margin)
SELECT 
    'Cost < Base Price' AS check_name,
    COUNT(*) AS error_count,
    CASE 
        WHEN COUNT(*) = 0 THEN '✅ PASSED'
        ELSE '❌ FAILED'
    END AS status
FROM products
WHERE unit_cost >= base_price;

-- Check 6: No duplicate transactions (using order_id + line_number)
SELECT 
    'No Duplicate Transactions' AS check_name,
    COUNT(*) AS duplicate_count,
    CASE 
        WHEN COUNT(*) = 0 THEN '✅ PASSED'
        ELSE '⚠️ WARNING: Duplicates found'
    END AS status
FROM (
    SELECT 
        order_id,
        line_number,
        COUNT(*) AS transaction_count
    FROM sales_transactions
    GROUP BY order_id, line_number
    HAVING COUNT(*) > 1
) AS duplicates;
```

